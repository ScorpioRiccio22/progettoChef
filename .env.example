# Copiare in .env (root del progetto) per personalizzare docker-compose.yml.
# Tutte le variabili hanno un default sensato per lo sviluppo locale: questo
# file serve solo se si vuole cambiare qualcosa (es. password del DB, durata
# del token, credenziali dell'admin di default).

DB_NAME=andreamoiochef
DB_USERNAME=andreamoiochef
DB_PASSWORD=andreamoiochef

JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
JWT_EXPIRATION_MINUTES=480

CORS_ALLOWED_ORIGINS=http://localhost:5173

ADMIN_SEED_ENABLED=true
ADMIN_SEED_EMAIL=admin@andreamoiochef.it
ADMIN_SEED_PASSWORD=admin123
ADMIN_SEED_FULL_NAME=Andrea Moio

# Recensioni Google (opzionali, sezione homepage). Se non impostate, il sito
# mostra automaticamente le testimonianze inserite a mano dal pannello admin.
# NON mettere qui la chiave reale in produzione: usare i secret dell'hosting.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_PLACE_ID=
GOOGLE_PLACES_CACHE_MINUTES=180
GOOGLE_PLACES_MAX_REVIEWS=6
