# Copiare in .env.staging SUL SERVER DI STAGING (non committare mai il file
# reale con le password: resta solo su questo file .example nel repo).
#
#   cp .env.staging.example .env.staging
#   nano .env.staging

# Dominio pubblico dello staging, es. staging.andreamoiochef.it
# Deve avere un record DNS di tipo A che punta all'IP del server, altrimenti
# Caddy non riesce a generare il certificato HTTPS.
STAGING_DOMAIN=staging.tuodominio.it

DB_NAME=andreamoiochef
DB_USERNAME=andreamoiochef
DB_PASSWORD=cambia-questa-password-in-una-sicura

# Generare con: openssl rand -base64 48
JWT_SECRET=cambia-questo-con-una-stringa-lunga-e-casuale-min-32-caratteri
JWT_EXPIRATION_MINUTES=480

ADMIN_SEED_ENABLED=true
ADMIN_SEED_EMAIL=admin@tuodominio.it
ADMIN_SEED_PASSWORD=cambia-questa-password-admin
ADMIN_SEED_FULL_NAME=Andrea Moio
