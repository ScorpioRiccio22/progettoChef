# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=andreamoiochef
DB_USERNAME=andreamoiochef
DB_PASSWORD=andreamoiochef

# CORS (origini separate da virgola)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# JWT
JWT_SECRET=changeit-dev-secret-please-override-in-prod-min-32-chars
JWT_EXPIRATION_MINUTES=480

# Admin di default (creato al primo avvio se admin_users è vuota)
ADMIN_SEED_ENABLED=true
ADMIN_SEED_EMAIL=admin@andreamoiochef.it
ADMIN_SEED_PASSWORD=admin123
ADMIN_SEED_FULL_NAME=Andrea Moio

# Storage upload
UPLOAD_DIR=/app/uploads
UPLOAD_PUBLIC_URL_PREFIX=/uploads

# Google Places (recensioni) - opzionale
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_PLACE_ID=
GOOGLE_PLACES_CACHE_MINUTES=180
GOOGLE_PLACES_MAX_REVIEWS=6
