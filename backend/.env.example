# Copiare in backend/.env e personalizzare per l'esecuzione locale (senza Docker).
# Quando si usa docker-compose, queste variabili sono già impostate in docker-compose.yml.

DB_URL=jdbc:postgresql://localhost:5432/andreamoiochef
DB_USERNAME=andreamoiochef
DB_PASSWORD=andreamoiochef

JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
JWT_EXPIRATION_MINUTES=480

CORS_ALLOWED_ORIGINS=http://localhost:5173

# Utente admin creato automaticamente al primo avvio se la tabella admin_users è vuota.
ADMIN_SEED_ENABLED=true
ADMIN_SEED_EMAIL=admin@andreamoiochef.it
ADMIN_SEED_PASSWORD=admin123
ADMIN_SEED_FULL_NAME=Andrea Moio
