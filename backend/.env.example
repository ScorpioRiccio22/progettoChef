# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=andreamoiochef
DB_USERNAME=andreamoiochef
# OBBLIGATORIA: l'app non si avvia se manca o è un valore segnaposto noto.
# Generane una con: openssl rand -base64 24
DB_PASSWORD=

# CORS (origini separate da virgola)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# JWT
# OBBLIGATORIA: minimo 32 caratteri, l'app non si avvia altrimenti.
# Generane uno con: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRATION_MINUTES=480

# Admin di default (creato al primo avvio se admin_users è vuota)
ADMIN_SEED_ENABLED=true
ADMIN_SEED_EMAIL=admin@andreamoiochef.it
# OBBLIGATORIA: l'app non si avvia se manca o è un valore segnaposto noto.
ADMIN_SEED_PASSWORD=
ADMIN_SEED_FULL_NAME=Andrea Moio

# Storage upload
UPLOAD_DIR=/app/uploads
UPLOAD_PUBLIC_URL_PREFIX=/uploads

# Google Places (recensioni) - opzionale
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_PLACE_ID=
GOOGLE_PLACES_CACHE_MINUTES=180
GOOGLE_PLACES_MAX_REVIEWS=6

# Email (SMTP, es. Brevo) - opzionale: se lasciate vuote, l'invio email è
# disabilitato (log di avviso invece di errore). Se ne imposti una, vanno
# impostate tutte e tre (SMTP_HOST/SMTP_USERNAME/SMTP_PASSWORD).
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER_EMAIL=noreply@andreamoiochef.it
SMTP_SENDER_NAME=Andrea Moio Chef

# Frontend (per i link nelle email: reset password, unsubscribe)
# SEGNAPOSTO: aggiornare quando il dominio definitivo sarà collegato.
FRONTEND_BASE_URL=https://staging.andreamoiochef.it

# Recupero password
PASSWORD_RESET_TOKEN_EXPIRATION_MINUTES=30
