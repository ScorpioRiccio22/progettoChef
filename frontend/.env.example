# Copiare in frontend/.env.local per lo sviluppo locale.
# In locale (senza Docker) Vite fa già da proxy su /api -> localhost:8080,
# quindi questa variabile è opzionale; va impostata esplicitamente solo se il
# backend non è su localhost:8080 oppure si vuole bypassare il proxy di Vite.
VITE_API_BASE_URL=http://localhost:8080/api
