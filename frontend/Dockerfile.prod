# Dockerfile di PRODUZIONE: build statica servita da nginx.
# Per lo sviluppo locale con hot-reload usare Dockerfile.dev (vedi docker-compose.yml).

# ---- Build stage ----
FROM node:20-alpine AS build
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .
RUN npm run build

# ---- Runtime stage ----
FROM nginx:1.27-alpine AS runtime

COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
